# ─────────────────────────────────────────────
#  genie_ui — frontend environment variables
#  Copy this file to .env.local and fill in real values
# ─────────────────────────────────────────────

# ── Supabase ──────────────────────────────────
# Public project URL — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# Service-role key — server-side ONLY, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Google OAuth ──────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── NextAuth v5 ───────────────────────────────
# Must match genie_sv NEXTAUTH_SECRET exactly
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-auth-secret
# Required in production / Docker (auto-detected in local dev)
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# ── Backend URL ───────────────────────────────
# Server-side rewrite target (used in next.config.ts)
# In Docker: set to the backend container name, e.g. http://genie-sv:8000
BACKEND_URL=http://localhost:8000
# Public backend URL for browser-side requests
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
