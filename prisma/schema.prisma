generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String   @id @default(uuid()) @db.Uuid
  email         String   @unique
  name          String?
  avatar_url    String?
  role          String   @default("user")
  is_approved   Boolean  @default(false)
  auth_provider String   @default("credentials")
  password_hash String?
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  updated_at    DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  input_sources      InputSource[]
  datasets           Dataset[]
  prompts            Prompt[]
  response_formats   ResponseFormat[]
  generations        Generation[]
  exported_documents ExportedDocument[]
  prompt_folders     PromptFolder[]
  prompt_chains      PromptChain[]

  @@map("users")
}

model Dataset {
  id          String   @id @default(uuid()) @db.Uuid
  user_id     String   @db.Uuid
  name        String
  description String?
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  user          User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  input_sources InputSource[]

  @@index([user_id])
  @@map("datasets")
}

model InputSource {
  id                String   @id @default(uuid()) @db.Uuid
  user_id           String   @db.Uuid
  dataset_id        String?  @db.Uuid
  name              String
  type              String
  original_filename String?
  storage_path      String?
  extracted_text    String?
  file_size         BigInt?
  metadata          Json     @default("{}")
  created_at        DateTime @default(now()) @db.Timestamptz(6)

  user               User               @relation(fields: [user_id], references: [id], onDelete: Cascade)
  dataset            Dataset?           @relation(fields: [dataset_id], references: [id], onDelete: Cascade)
  generation_sources GenerationSource[]

  @@index([user_id])
  @@index([dataset_id])
  @@map("input_sources")
}

model PromptFolder {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    String?  @db.Uuid
  name       String
  is_default Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamptz(6)

  user    User?    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  prompts Prompt[]

  @@index([user_id])
  @@map("prompt_folders")
}

model Prompt {
  id                 String   @id @default(uuid()) @db.Uuid
  user_id            String?  @db.Uuid
  folder_id          String?  @db.Uuid
  name               String
  text               String
  is_default         Boolean  @default(false)
  response_format_id String?  @db.Uuid
  created_at         DateTime @default(now()) @db.Timestamptz(6)
  updated_at         DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  user            User?           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  folder          PromptFolder?   @relation(fields: [folder_id], references: [id], onDelete: SetNull)
  response_format ResponseFormat? @relation(fields: [response_format_id], references: [id], onDelete: SetNull)
  chain_steps     PromptChainStep[]

  @@index([user_id])
  @@index([folder_id])
  @@map("prompts")
}

model ResponseFormat {
  id            String   @id @default(uuid()) @db.Uuid
  user_id       String?  @db.Uuid
  name          String
  description   String?
  template_text String
  is_default    Boolean  @default(false)
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  updated_at    DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  user              User?             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  paired_prompts    Prompt[]
  chain_step_formats PromptChainStep[]

  @@index([user_id])
  @@map("response_formats")
}

model PromptChain {
  id          String   @id @default(uuid()) @db.Uuid
  user_id     String   @db.Uuid
  name        String
  description String?
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  user        User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  steps       PromptChainStep[]
  generations Generation[]

  @@index([user_id])
  @@map("prompt_chains")
}

model PromptChainStep {
  id                 String  @id @default(uuid()) @db.Uuid
  chain_id           String  @db.Uuid
  prompt_id          String  @db.Uuid
  step_order         Int
  response_format_id String? @db.Uuid

  chain           PromptChain     @relation(fields: [chain_id], references: [id], onDelete: Cascade)
  prompt          Prompt          @relation(fields: [prompt_id], references: [id], onDelete: Cascade)
  response_format ResponseFormat? @relation(fields: [response_format_id], references: [id], onDelete: SetNull)

  @@unique([chain_id, step_order])
  @@index([chain_id])
  @@map("prompt_chain_steps")
}

model Generation {
  id                   String   @id @default(uuid()) @db.Uuid
  user_id              String   @db.Uuid
  title                String   @default("Untitled")
  prompt_text          String
  response_format_text String?
  model_used           String
  response_content     String?
  status               String   @default("pending")
  error_message        String?
  prompt_chain_id      String?  @db.Uuid
  created_at           DateTime @default(now()) @db.Timestamptz(6)

  user               User               @relation(fields: [user_id], references: [id], onDelete: Cascade)
  prompt_chain       PromptChain?       @relation(fields: [prompt_chain_id], references: [id], onDelete: SetNull)
  generation_sources GenerationSource[]
  exported_documents ExportedDocument[]

  @@index([user_id])
  @@map("generations")
}

model GenerationSource {
  generation_id String @db.Uuid
  source_id     String @db.Uuid

  generation Generation  @relation(fields: [generation_id], references: [id], onDelete: Cascade)
  source     InputSource @relation(fields: [source_id], references: [id], onDelete: Cascade)

  @@id([generation_id, source_id])
  @@map("generation_sources")
}

model ExportedDocument {
  id            String   @id @default(uuid()) @db.Uuid
  user_id       String   @db.Uuid
  generation_id String   @db.Uuid
  format        String
  storage_path  String
  filename      String
  file_size     BigInt?
  created_at    DateTime @default(now()) @db.Timestamptz(6)

  user       User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  generation Generation @relation(fields: [generation_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([generation_id])
  @@map("exported_documents")
}
